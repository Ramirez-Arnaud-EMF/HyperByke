{
  "name": "hyperbyke-tests",
  "version": "1.0.0",
  "description": "Tests unitaires, intégration et fonctionnels du projet HyperByke",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --coverage",
    "test:verbose": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --verbose",
    "test:integration": "vitest run --config vitest.config.js",
    "test:integration:watch": "vitest --config vitest.config.js",
    "test:fonctionnel": "cypress run",
    "test:fonctionnel:open": "cypress open",
    "lint": "eslint \"client/service/**/*.js\" \"server/app/**/*.js\"",
    "lint:fix": "eslint --fix \"client/service/**/*.js\" \"server/app/**/*.js\""
  },
  "author": "Arnaud Ramirez",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^13.17.0",
    "eslint": "^9.26.0",
    "jest": "^29.7.0",
    "vitest": "^3.1.3"
  }
}
